	$(MAKE) $(MAKESILENT) -f CMakeFiles/forza_cubey.dir/build.make CMakeFiles/forza_cubey.dir/src/renderer/Shader.cpp.i
.PHONY : src/renderer/Shader.cpp.i

src/renderer/Shader.s: src/renderer/Shader.cpp.s
.PHONY : src/renderer/Shader.s

